// Hotel + Restaurant ERP System
// RRP Dream Inn (Hotel) + CloudView (Restaurant)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & RBAC
// ============================================

enum RoleType {
  ADMIN
  HOTEL_STAFF
  RESTAURANT_STAFF
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      RoleType @default(HOTEL_STAFF)
  active    Boolean  @default(true)
  phone     String?
  avatar    String?  @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings          Booking[]
  restaurantOrders  RestaurantOrder[]
  activityLogs      ActivityLog[]
  payments          Payment[]
  housekeepingTasks HousekeepingTask[]

  @@map("users")
}

// ============================================
// HOTEL - ROOM MANAGEMENT
// ============================================

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
}

model RoomType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  basePrice   Float
  capacity    Int      @default(2)
  hourlyRate  Float?
  amenities   String? // JSON string of amenities
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms Room[]

  @@map("room_types")
}

model Room {
  id         String     @id @default(cuid())
  roomNumber String     @unique
  floor      Int        @default(1)
  status     RoomStatus @default(AVAILABLE)
  typeId     String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  type             RoomType           @relation(fields: [typeId], references: [id])
  bookings         Booking[]
  housekeeping     HousekeepingTask[]
  restaurantOrders RestaurantOrder[]

  @@map("rooms")
}

// ============================================
// HOTEL - GUEST/CUSTOMER MANAGEMENT
// ============================================

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String
  address   String?
  idType    String? // passport, national_id, etc.
  idNumber  String?
  idDocPath String? // uploaded ID document path
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@map("customers")
}

// ============================================
// HOTEL - BOOKING MANAGEMENT
// ============================================

enum BookingStatus {
  RESERVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

model Booking {
  id              String        @id @default(cuid())
  customerId      String
  roomId          String
  status          BookingStatus @default(RESERVED)
  checkIn         DateTime
  checkOut        DateTime
  actualCheckIn   DateTime?
  actualCheckOut  DateTime?
  adults          Int           @default(1)
  children        Int           @default(0)
  totalRoomCharge Float         @default(0)
  advancePayment  Float         @default(0)
  initialPayment  Float         @default(0)
  dueAmount       Float         @default(0)
  notes           String?
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer         Customer          @relation(fields: [customerId], references: [id])
  room             Room              @relation(fields: [roomId], references: [id])
  creator          User              @relation(fields: [createdBy], references: [id])
  charges          RoomCharge[]
  payments         Payment[]
  invoices         Invoice[]
  restaurantOrders RestaurantOrder[]

  @@map("bookings")
}

// ============================================
// HOTEL - ROOM CHARGES
// ============================================

enum ChargeType {
  ROOM_RATE
  LATE_CHECKOUT
  EXTRA_SERVICE
  MINIBAR
  LAUNDRY
  OTHER
}

model RoomCharge {
  id          String     @id @default(cuid())
  bookingId   String
  chargeType  ChargeType @default(ROOM_RATE)
  description String
  amount      Float
  quantity    Int        @default(1)
  chargeDate  DateTime   @default(now())
  createdAt   DateTime   @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("room_charges")
}

// ============================================
// RESTAURANT - MENU MANAGEMENT
// ============================================

model MenuCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id              String   @id @default(cuid())
  categoryId      String
  name            String
  description     String?
  price           Float
  image           String?  @db.LongText
  available       Boolean  @default(true)
  isVeg           Boolean  @default(true)
  preparationTime Int? // in minutes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category   MenuCategory @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@map("menu_items")
}

// ============================================
// RESTAURANT - TABLE MANAGEMENT
// ============================================

model RestaurantTable {
  id          String   @id @default(cuid())
  tableNumber String
  capacity    Int      @default(4)
  status      String   @default("available") // available, occupied, reserved
  location    String? // indoor, outdoor, vip
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders RestaurantOrder[]

  @@map("restaurant_tables")
}

// ============================================
// RESTAURANT - ORDER MANAGEMENT
// ============================================

enum OrderType {
  DINE_IN
  TAKEAWAY
  ROOM_SERVICE
}

enum OrderStatus {
  PENDING
  COOKING
  READY
  DELIVERED
  CANCELLED
}

model RestaurantOrder {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  orderType     OrderType   @default(DINE_IN)
  status        OrderStatus @default(PENDING)
  roomId        String? // nullable - only for room_service
  tableId       String? // nullable - only for dine_in
  bookingId     String? // auto-linked from room
  customerName  String? // for takeaway
  customerPhone String? // for takeaway
  subtotal      Float       @default(0)
  discount      Float       @default(0)
  vatAmount     Float       @default(0)
  vatPercent    Float       @default(0)
  totalAmount   Float       @default(0)
  notes         String?
  createdBy     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  room     Room?            @relation(fields: [roomId], references: [id])
  table    RestaurantTable? @relation(fields: [tableId], references: [id])
  booking  Booking?         @relation(fields: [bookingId], references: [id])
  creator  User             @relation(fields: [createdBy], references: [id])
  items    OrderItem[]
  payments Payment[]

  @@map("restaurant_orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int     @default(1)
  price      Float // price at time of order
  notes      String?
  kotStatus  String  @default("pending") // pending, cooking, ready

  order    RestaurantOrder @relation(fields: [orderId], references: [id])
  menuItem MenuItem        @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

// ============================================
// PAYMENT SYSTEM
// ============================================

enum PaymentMethod {
  CASH
  CARD
  MOBILE_BANKING
}

enum PaymentType {
  ADVANCE
  INITIAL
  FINAL
  PARTIAL
  RESTAURANT
}

model Payment {
  id          String        @id @default(cuid())
  amount      Float
  method      PaymentMethod @default(CASH)
  paymentType PaymentType
  bookingId   String? // for hotel payments
  orderId     String? // for restaurant payments
  invoiceId   String? // linked to invoice
  reference   String? // transaction reference
  notes       String?
  receivedBy  String
  createdAt   DateTime      @default(now())

  booking  Booking?         @relation(fields: [bookingId], references: [id])
  order    RestaurantOrder? @relation(fields: [orderId], references: [id])
  invoice  Invoice?         @relation(fields: [invoiceId], references: [id])
  receiver User             @relation(fields: [receivedBy], references: [id])

  @@map("payments")
}

// ============================================
// INVOICE SYSTEM
// ============================================

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  CANCELLED
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  bookingId     String
  roomCharges   Float         @default(0)
  foodCharges   Float         @default(0)
  extraCharges  Float         @default(0)
  subtotal      Float         @default(0)
  discount      Float         @default(0)
  vatAmount     Float         @default(0)
  totalAmount   Float         @default(0)
  paidAmount    Float         @default(0)
  dueAmount     Float         @default(0)
  status        InvoiceStatus @default(DRAFT)
  issuedAt      DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking  Booking       @relation(fields: [bookingId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  itemType    String // room_charge, food_order, extra_service
  referenceId String? // ID of the charge or order
  description String
  quantity    Int     @default(1)
  unitPrice   Float
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_items")
}

// ============================================
// HOUSEKEEPING
// ============================================

enum HousekeepingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model HousekeepingTask {
  id          String             @id @default(cuid())
  roomId      String
  taskType    String // cleaning, maintenance, deep_clean
  status      HousekeepingStatus @default(PENDING)
  assignedTo  String
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  room     Room @relation(fields: [roomId], references: [id])
  assigned User @relation(fields: [assignedTo], references: [id])

  @@map("housekeeping_tasks")
}

// ============================================
// INVENTORY / STOCK
// ============================================

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  category    String?
  unit        String // kg, piece, liter
  quantity    Float    @default(0)
  minQuantity Float    @default(0) // reorder level
  costPerUnit Float?
  supplier    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions InventoryTransaction[]

  @@map("inventory_items")
}

model InventoryTransaction {
  id        String   @id @default(cuid())
  itemId    String
  type      String // in, out, waste
  quantity  Float
  notes     String?
  createdBy String
  createdAt DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id])

  @@map("inventory_transactions")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  message   String
  type      String // order_ready, checkout_alert, low_stock, etc.
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ============================================
// ACTIVITY LOGS
// ============================================

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  module    String // hotel, restaurant, billing, etc.
  details   String? // JSON string
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// ============================================
// SYSTEM SETTINGS
// ============================================

model Setting {
  id    String  @id @default(cuid())
  key   String  @unique
  value String
  group String? // hotel, restaurant, general

  @@map("settings")
}
